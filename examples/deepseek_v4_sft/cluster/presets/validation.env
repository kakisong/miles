#!/usr/bin/env bash
# Stage B validation — 64 GPU,20-iter OpenHermes SFT。等价于旧 run_sft_validation.sh。
# 用途:验 SFT loss 曲线随训练单调下降。

export PRESET_NAME=validation
export PRESET_RUN_ID_PREFIX=stageBval

# Workload
export PRESET_NUM_ROLLOUT=20
export PRESET_GLOBAL_BATCH_SIZE=128
export PRESET_ROLLOUT_BATCH_SIZE=128
export PRESET_SAVE_INTERVAL=100             # 20 步只在最后存,避免 4 次 ~250s save
export PRESET_SAVE_RETAIN_INTERVAL=100

# Parallelism(同 smoke)
export PRESET_TP=8
export PRESET_PP=8
export PRESET_CP=1
export PRESET_EP=8
export PRESET_ETP=1
export PRESET_DECODER_FIRST_PIPELINE_NUM_LAYERS=4
export PRESET_DECODER_LAST_PIPELINE_NUM_LAYERS=3

export PRESET_ATTN_IMPL=tilelang

export PRESET_LR=5e-6
export PRESET_LR_DECAY_STYLE=constant
