#!/usr/bin/env bash
# Long-context training —— CP=8 + 256K context,目标 H200 集群。
#
# 在 H200 16 节点(128 GPU,2 个完整副本)上的典型配置。
# 每副本 = TP=8 × PP=4 × CP=8 = 256 ranks,需要 32 节点 → 这个 preset 假设
# 跑在 ≥32 节点的 H200 集群,DP=1 + 真做 256K。
#
# H20 集群上跑这个 preset 数学上不行(TP×PP×CP=512 GPUs/replica,远超 64)。

export PRESET_NAME=long_context
export PRESET_RUN_ID_PREFIX=stageLC

# Workload —— 5 步冒烟,真用要改 num-rollout
export PRESET_NUM_ROLLOUT=5
export PRESET_GLOBAL_BATCH_SIZE=128
export PRESET_ROLLOUT_BATCH_SIZE=128
export PRESET_SAVE_INTERVAL=100
export PRESET_SAVE_RETAIN_INTERVAL=100

# Parallelism for 256K
# 1 副本 = TP=8 × PP=4 × CP=8 = 256 GPUs
# EP=8 在 MoE 层共享 ranks
export PRESET_TP=8
export PRESET_PP=4
export PRESET_CP=8
export PRESET_EP=8
export PRESET_ETP=1
export PRESET_DECODER_FIRST_PIPELINE_NUM_LAYERS=11
export PRESET_DECODER_LAST_PIPELINE_NUM_LAYERS=10

# Override HW max-tokens-per-gpu for 256K target
# 256K / CP=8 = 32K per rank
export HW_MAX_TOKENS_PER_GPU=32768

export PRESET_ATTN_IMPL=tilelang

export PRESET_LR=5e-6
export PRESET_LR_DECAY_STYLE=constant
