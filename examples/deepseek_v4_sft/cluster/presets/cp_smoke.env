#!/usr/bin/env bash
# CP=2 + 8K context smoke — 64 GPU,5-iter,等价于 run_cp_smoke.sh。
# 用途:验证 Megatron CP × V4 sparse-MLA 路径,为 H200 上 CP=8 + 256K 铺路。
#
# 配置变化(相对 smoke/validation):
#   - PP 8 → 4(腾 ranks 给 CP)
#   - CP 1 → 2,max-tokens × CP = 全局 packed seq 8K
#   - PP=4 layer 分布:11/11/11/10

export PRESET_NAME=cp_smoke
export PRESET_RUN_ID_PREFIX=stageB0cp

# Workload
export PRESET_NUM_ROLLOUT=5
export PRESET_GLOBAL_BATCH_SIZE=128
export PRESET_ROLLOUT_BATCH_SIZE=128
export PRESET_SAVE_INTERVAL=100
export PRESET_SAVE_RETAIN_INTERVAL=100

# Parallelism(CP=2 关键)
export PRESET_TP=8
export PRESET_PP=4
export PRESET_CP=2
export PRESET_EP=8
export PRESET_ETP=1
export PRESET_DECODER_FIRST_PIPELINE_NUM_LAYERS=11
export PRESET_DECODER_LAST_PIPELINE_NUM_LAYERS=10

export PRESET_ATTN_IMPL=tilelang

export PRESET_LR=5e-6
export PRESET_LR_DECAY_STYLE=constant
