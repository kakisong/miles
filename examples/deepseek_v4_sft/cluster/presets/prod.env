#!/usr/bin/env bash
# Production SFT —— 长跑配置。同 validation 的并行结构,但 prod 友好的 save 间隔。
#
# 默认 200 步(~47 min @ tilelang 14s/step on H20 64-GPU)。
# 真生产想跑更多用 CLI 覆盖:
#   bash run.sh prod --num-rollout 1600     (~6.3h 全跑)
# 或编辑下面的值。

export PRESET_NAME=prod
export PRESET_RUN_ID_PREFIX=stageProd

# Workload
export PRESET_NUM_ROLLOUT=200                # 默认 200 步,~47 min
export PRESET_GLOBAL_BATCH_SIZE=128
export PRESET_ROLLOUT_BATCH_SIZE=128
export PRESET_SAVE_INTERVAL=50               # 每 50 步存 ckpt
export PRESET_SAVE_RETAIN_INTERVAL=200       # 每 200 步留永久 ckpt,中间滚掉

# Parallelism(同 validation,稳定路径)
export PRESET_TP=8
export PRESET_PP=8
export PRESET_CP=1
export PRESET_EP=8
export PRESET_ETP=1
export PRESET_DECODER_FIRST_PIPELINE_NUM_LAYERS=4
export PRESET_DECODER_LAST_PIPELINE_NUM_LAYERS=3

export PRESET_ATTN_IMPL=tilelang

# 生产 LR:5e-6 偏低,真 SFT 推荐 1e-5 ~ 5e-5,LR-decay cosine + warmup。
# 当前默认沿用 validation 的 5e-6 constant —— 跑通验证用。
# 真生产改 cosine + 提高 LR(需要在 CLI 加 --lr-warmup-iters):
#   PRESET_LR=2e-5  PRESET_LR_DECAY_STYLE=cosine
export PRESET_LR=5e-6
export PRESET_LR_DECAY_STYLE=constant
