#!/usr/bin/env bash
# Stage B0 smoke — 64 GPU,2-iter dry-run。等价于旧 run_smoke.sh。
# 用途:验证 V4-Flash 在 64 卡上 forward/backward 能跑、ckpt 能存。

export PRESET_NAME=smoke
export PRESET_RUN_ID_PREFIX=stageB0

# Workload
export PRESET_NUM_ROLLOUT=2
export PRESET_GLOBAL_BATCH_SIZE=128
export PRESET_ROLLOUT_BATCH_SIZE=128
export PRESET_SAVE_INTERVAL=1
export PRESET_SAVE_RETAIN_INTERVAL=2

# Parallelism
export PRESET_TP=8
export PRESET_PP=8
export PRESET_CP=1
export PRESET_EP=8
export PRESET_ETP=1
export PRESET_DECODER_FIRST_PIPELINE_NUM_LAYERS=4
export PRESET_DECODER_LAST_PIPELINE_NUM_LAYERS=3

# Attention impl
export PRESET_ATTN_IMPL=tilelang

# Optimizer
export PRESET_LR=5e-6
export PRESET_LR_DECAY_STYLE=constant
