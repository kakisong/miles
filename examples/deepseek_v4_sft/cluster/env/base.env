#!/usr/bin/env bash
# V4-Flash 项目级路径约定,与具体集群无关。
# 由 cluster_*.env 提供 V4_WORK,这里推导其余路径。
#
# 用法:被 ../env.sh shim 间接 source,**不要直接 source**(没有 V4_WORK 会失败)。

: "${V4_WORK:?V4_WORK must be set by cluster_*.env before sourcing base.env}"

# 项目布局(相对 V4_WORK)
export V4_MILES=$V4_WORK/miles
# Megatron-LM 用 CFS 上的 radixark/Megatron-LM dsv4-pr28 分支
# 容器内 /root/Megatron-LM 是 miles-main HEAD,不含 sqrtsoftplus PR #28
# CFS dsv4-pr28 = miles-main + PR #28 (sqrtsoftplus + 部分 V4 args)
export V4_MEGATRON=$V4_WORK/Megatron-LM

# 数据 / 模型
export V4_MODELS=$V4_WORK/models
export V4_DATA=$V4_WORK/data
export V4_OUT=$V4_WORK/outputs
export V4_HF_DIR=$V4_MODELS/DeepSeek-V4-Flash-FP8        # 软链 → DeepSeek-V4-Flash
# 指向我们自己 cast 出的真正 unpacked BF16 HF dir
# (DeepSeek-V4-Flash-FP8-bf16 是 community 的 packed FP4/FP8 dir,缺 scale,无法用)
# 由 examples/deepseek_v4_sft/tools/megablocks_to_hf_bf16.py 从 SRC megablocks dir cast 而来
export V4_BF16_DIR=$V4_MODELS/DeepSeek-V4-Flash-bf16-unpacked
export V4_TORCH_DIST=$V4_MODELS/DeepSeek-V4-Flash-FP8_torch_dist
export V4_SFT_DATA=$V4_DATA/openhermes_v4.parquet

# HF cache(覆盖系统级 profile.d 写不动的目录)
export V4_HF_HOME=$V4_WORK/.cache/huggingface
mkdir -p "$V4_HF_HOME"

mkdir -p "$V4_OUT"
