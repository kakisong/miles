#!/usr/bin/env bash
# 当前 8 节点 H20 集群的身份。
#
# 这个文件只描述"这个集群是什么样的",不包含路径推导(在 base.env)、
# 硬件参数(在 hw/h20.env)、workload(在 presets/*.env)。
#
# 用法:经 ../env.sh shim 间接 source,V4_CLUSTER=h20_8node 时被选中。

# 集群标识(用于选 hw/$V4_GPU_MODEL.env)
export V4_CLUSTER_NAME=h20_8node
export V4_GPU_MODEL=h20

# 拓扑
export V4_NUM_NODES=8
export V4_NUM_GPUS_PER_NODE=8
export V4_MASTER_IP=10.0.8.17
export V4_WORKER_IPS="10.0.8.10 10.0.8.11 10.0.8.12 10.0.8.13 10.0.8.14 10.0.8.15 10.0.8.16"
export V4_ALL_IPS="$V4_MASTER_IP $V4_WORKER_IPS"

# 这个集群的 V4-Flash artifact 根(CFS,所有节点共享)
export V4_WORK=/data_fast_v3/kaynzhang/v4-sft

# 容器
# dev 跟 latest 在 docker hub 上指向同一 image (id 82c52c12bf24,Dockerfile.dev build)
# 镜像内置 V4 配套:radixark/Megatron-LM miles-main + sgl-workspace/sglang sglang-miles 分支
# + yushengsu-thu/Megatron-Bridge + yueming-yuan/miles-wheels
# 注:gb300-dev-dskv4 是 arm64 GB300 build,本 H20 集群用不了
export V4_IMAGE=radixark/miles:dev
export V4_CONTAINER=miles-v4-sft

# Ray + 监控端口
export V4_RAY_PORT=6379
export V4_DASHBOARD_PORT=8201        # 从 8265 改;符合可暴露端口列表

# 监控集成(Ray dashboard 嵌入 Grafana)
export V4_PROMETHEUS_PORT=40001
export V4_GRAFANA_PORT=7777
export V4_GRAFANA_HOST=http://10.0.8.17:${V4_GRAFANA_PORT}
export V4_PROMETHEUS_HOST=http://10.0.8.17:${V4_PROMETHEUS_PORT}

# Outbound proxy(下游 ssh 时也要 export)
export V4_HTTP_PROXY=http://172.26.0.3:8081

# Docker bind mounts —— 容器内挂载的主机路径(每条都是 src:dst 形式)。
# 至少要包含 V4_WORK 所在的存储 + InfiniBand 设备。
export V4_DOCKER_MOUNTS=(
  "/data_fast_v3:/data_fast_v3"     # CFS,V4_WORK 所在
  "/data0:/data0"                   # local NVMe scratch
  "/dev/infiniband:/dev/infiniband" # IB
)
