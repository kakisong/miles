#!/usr/bin/env bash
# H200 集群配置模板 —— 复制成 cluster_h200_<your-name>.env 后填实际值。
# 用法:V4_CLUSTER=h200_<your-name> bash run.sh <preset>

# 集群标识(用于选 hw/$V4_GPU_MODEL.env)
export V4_CLUSTER_NAME=h200_TEMPLATE
export V4_GPU_MODEL=h200

# 拓扑 —— 按实际填
export V4_NUM_NODES=16                       # 例:16 节点 × 8 GPU = 128 H200
export V4_NUM_GPUS_PER_NODE=8
export V4_MASTER_IP=10.x.x.x                 # ray head 所在节点
export V4_WORKER_IPS="10.x.x.x 10.x.x.x ..." # 空格分隔,N-1 个 worker IP
export V4_ALL_IPS="$V4_MASTER_IP $V4_WORKER_IPS"

# V4-Flash artifact 根 —— 必须是所有节点都能访问的同一路径
# 推荐 CFS / Lustre 等共享存储。如果是 local NVMe,需要 rsync 同步到所有节点。
export V4_WORK=/your/shared/storage/v4-sft

# 容器 —— 见 BOOTSTRAP.md 关于 image 同步
export V4_IMAGE=radixark/miles:dev           # 或其他 V4 兼容 image
export V4_CONTAINER=miles-v4-sft

# Ray + 监控端口 —— 按集群 firewall 政策选
export V4_RAY_PORT=6379
export V4_DASHBOARD_PORT=8201
export V4_PROMETHEUS_PORT=40001
export V4_GRAFANA_PORT=7777
export V4_GRAFANA_HOST=http://${V4_MASTER_IP}:${V4_GRAFANA_PORT}
export V4_PROMETHEUS_HOST=http://${V4_MASTER_IP}:${V4_PROMETHEUS_PORT}

# Outbound proxy —— 没代理就 unset
# export V4_HTTP_PROXY=http://your-proxy:port
unset V4_HTTP_PROXY

# Docker bind mounts —— 至少要包含 V4_WORK 所在存储 + InfiniBand 设备
export V4_DOCKER_MOUNTS=(
  "/your/shared/storage:/your/shared/storage"   # 与 V4_WORK 同一根
  "/dev/infiniband:/dev/infiniband"
)
