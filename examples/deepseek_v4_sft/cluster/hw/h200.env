#!/usr/bin/env bash
# H200(141 GB HBM3e,~989 TFLOPs BF16,4.8 TB/s,132 SMs)默认硬件参数。
# 相对 H20:显存 1.47×,带宽 1.2×,BF16 算力 6.7×。
#
# 由 run.sh 在 source presets/* 之前 source。preset 可以覆盖任一项。

# 单卡(单 CP-rank)token 上限。H200 显存富裕,默认 16K(H20 是 4K)。
# 长 context preset 可以覆盖到 32K。
export HW_MAX_TOKENS_PER_GPU=16384

# Recompute:H200 算力强 + 显存大,默认 selective(只重算 attention)。
# 如果还是 OOM 改 full;如果显存富余可以再去掉。
export HW_RECOMPUTE_GRANULARITY=selective
export HW_RECOMPUTE_METHOD=
export HW_RECOMPUTE_NUM_LAYERS=

# FP8 训练:H200 FP8 算力 ~1979 TF,理论 2× over BF16。
# 但 V4 sparse-MLA tilelang kernel 当前是 BF16 输入,转 FP8 要 kernel 改造,
# 现阶段先关。等 kernel 升级后开。
export HW_FP8_ENABLED=0

# Tilelang block size for H200(132 SM,vs H20 78)
# 现 V4 kernel 自适应,这两个仅供未来 hand-tune
export HW_TILELANG_BLOCK_H=128
export HW_TILELANG_BLOCK_SIZE=64

# NCCL 调优
export HW_NCCL_NVLS_ENABLE=1
