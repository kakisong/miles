#!/usr/bin/env bash
# H20(96 GB HBM3,~148 TFLOPs BF16,4.0 TB/s)默认硬件参数。
# 由 run.sh 在 source presets/* 之前 source。preset 可以覆盖任一项。

# 单卡(单 CP-rank)token 上限。H20 96 GB 显存挤出来的安全值。
export HW_MAX_TOKENS_PER_GPU=4096

# Recompute:H20 算力受限 + 显存中等紧,默认开 full 重算 1 layer。
export HW_RECOMPUTE_GRANULARITY=full
export HW_RECOMPUTE_METHOD=uniform
export HW_RECOMPUTE_NUM_LAYERS=1

# FP8 训练:H20 FP8 算力 ~296 TF,相对 BF16 没多大优势,默认关。
export HW_FP8_ENABLED=0

# Tilelang kernel block size(目前 V4 kernel 自适应,这两个仅供未来 tune)
export HW_TILELANG_BLOCK_H=64
export HW_TILELANG_BLOCK_SIZE=32

# NCCL 调优(NVL switch enable for H20 NVLink 4)
export HW_NCCL_NVLS_ENABLE=1
